{
  "sound": false,
  "notification": true,
  "timeout": 2,
  "showProjectName": true,
  "notificationSystem": "notify-send",
  "command": {
      "enabled": true,
      "path": "/usr/bin/bash",
      "args": ["-c", "test \"{message}\" != subagent_complete && notify-send -a opencode -u low 'opencode' \"{message}\""],
      "minDuration": 1
  },
  "messages": {
    "permission": "Action required",
    "complete": "Done!",
    "subagent_complete": "Subagent complete",
    "error": "Something went wrong",
    "question": "Input needed"
  }
}
