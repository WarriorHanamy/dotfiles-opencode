{
    "$schema": "https://opencode.ai/config.json",
    "experimental": {
        "mcp_timeout": 120000
    },
    "provider": {
        "mimo": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "MiMo",
            "options": {
                "baseURL": "https://token-plan-cn.xiaomimimo.com/v1",
                "apiKey": "{env:XIAOMI_TOKEN}"
            },
            "models": {
                "mimo-v2-pro": {
                    "name": "MiMo-V2-Pro",
                    "limit": {
                        "context": 1048576,
                        "output": 131072
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    }
                },
                "mimo-v2.5-pro": {
                    "name": "MiMo-V2.5-Pro",
                    "limit": {
                        "context": 1048576,
                        "output": 131072
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    }
                }
            }
        },
        "stp-flash": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "https://api.stepfun.com/v1",
                "apiKey": "{env:STP_FLASH_TOKEN}"
            },
            "models": {
                "step-3.5-flash": {
                    "name": "Step-3.5-Flash",
                    "limit": {
                        "context": 131072,
                        "output": 131072
                    },
                    "modalities": {
                        "input": ["text"],
                        "output": ["text"]
                    }
                }
             }
         },
        "deepseek": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "https://api.deepseek.com",
                "apiKey": "{env:DEEPSEEK_TOKEN}"
            },
            "models": {
                "deepseek-v4-flash": {
                    "name": "DeepSeek-V4-Flash",
                    "limit": {
                        "context": 1048576,
                        "output": 131072
                    },
                    "modalities": {
                        "input": ["text"],
                        "output": ["text"]
                    }
                },
                "deepseek-v4-pro": {
                    "name": "DeepSeek-V4-Pro",
                    "limit": {
                        "context": 1048576,
                        "output": 131072
                    },
                    "modalities": {
                        "input": ["text"],
                        "output": ["text"]
                    }
                }
            }
        }
    },
    "model": "mimo/mimo-v2.5-pro",
    // "model": "deepseek/deepseek-reasoner",
    // "model": "openrouter-compatible/anthropic/claude-sonnet-4.6",
    "default_agent": "build",
    "agent": {
        "build": {
            "model": "deepseek/deepseek-v4-pro"
        },
        "plan": {
            "model": "deepseek/deepseek-v4-pro"
        },
        "explore": {
            "model": "deepseek/deepseek-v4-flash",
            "thinking": {
                "type": "disabled"
            }
        }
    },
    "mcp": {
        "context7": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "{env:CONTEXT7_TOKEN}"
            ],
            "enabled": true,
        },
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest",
                "--no-usage-statistics",
                "--headless", "true"
            ],
            "enabled": false
        },
        "grep": {
            "type": "remote",
            "url": "https://mcp.grep.app",
            "enabled": true,
        }
    },
    "permission": {
        "external_directory": {
            "*": "ask",
            "~/.config/opencode/skills/*": "allow",
            "/tmp/*": "allow",
        }
    },
    "formatter": {
        "stylua": {
            "command": ["stylua", "-", "$FILE"],
            "extensions": [".lua"]
        }
    },
    "plugin": [
        "@franlol/opencode-md-table-formatter@0.0.3",
        "opencode-pty@0.2.1",
        "@mohak34/opencode-notifier@0.1.19"
    ],
    "lsp": {
        "pyright": {
           "disabled": true
        },
        "clangd": {
           "disabled": true
        }
    }
}
