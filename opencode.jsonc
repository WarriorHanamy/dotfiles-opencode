{
    "$schema": "https://opencode.ai/config.json",
    "experimental": {
        "mcp_timeout": 120000
    },
    "provider": {
        "mimo": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "MiMo",
            "options": {
                "baseURL": "https://token-plan-cn.xiaomimimo.com/anthropic",
                "apiKey": "{env:XIAOMI_TOKEN}"
            },
            "models": {
                "mimo-v2-pro": {
                    "name": "MiMo-V2-Pro",
                    "limit": {
                        "context": 1048576,
                        "output": 131072
                    },
                    "modalities": {
                        "input": [
                            "text"
                        ],
                        "output": [
                            "text"
                        ]
                    }
                }
            }
        },
        "zhipuai-coding-plan": {
            "options": {
                "apiKey": "{env:Z_AI_TOKEN}"
            }
        },
        "deepseek": {
            "options": {
                "apiKey": "{env:DEEPSEEK_TOKEN}"
            }
        },
    },
    "model": "mimo/mimo-v2-pro",
    // "model": "zhipuai-coding-plan/glm-5",
    // "model": "deepseek/deepseek-reasoner",
    // "model": "openrouter-compatible/anthropic/claude-sonnet-4.6",
    "small_model": "zhipuai-coding-plan-coding-plan/glm-4.7",
    "default_agent": "build",
    "agent": {
        "build": {
            "model": "mimo/mimo-v2-pro"
        },
        "plan": {
            "model": "mimo/mimo-v2-pro"
        }
    },
    "mcp": {
        "zai-mcp-server": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@z_ai/mcp-server"
            ],
            "environment": {
                "Z_AI_MODE": "ZHIPU",
                "Z_AI_API_KEY": "{env:Z_AI_TOKEN}"
            },
            "enabled": false,
        },
        "web-search-prime": {
            "type": "remote",
            "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
            "headers": {
                "Authorization": "Bearer {env:Z_AI_TOKEN}"
            },
            "enabled": false,
        },
        "web-reader": {
            "type": "remote",
            "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp",
            "headers": {
                "Authorization": "Bearer {env:Z_AI_TOKEN}"
            },
            "enabled": true,
        },
        "zread": {
            "type": "remote",
            "url": "https://open.bigmodel.cn/api/mcp/zread/mcp",
            "headers": {
                "Authorization": "Bearer {env:Z_AI_TOKEN}"
            },
            "enabled": false,
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ],
            "enabled": false,
        },
        "context7": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "{env:CONTEXT7_TOKEN}"
            ],
            "enabled": true,
        },
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest",
                "--no-usage-statistics",
                "--headless", "true"
            ],
            "enabled": false
        },
        "grep": {
            "type": "remote",
            "url": "https://mcp.grep.app",
            "enabled": true,
        }
    },
    "permission": {
        "external_directory": {
            "*": "ask",
            "~/.config/opencode/skills/*": "allow",
            "/tmp/*": "allow",
        }
    },
    "formatter": {
        "stylua": {
            "command": ["stylua", "-", "$FILE"],
            "extensions": [".lua"]
        }
    },
    "plugin": [
        "@franlol/opencode-md-table-formatter@0.0.3",
        "opencode-pty@0.2.1",
        "@mohak34/opencode-notifier@0.1.19"
    ],
    "lsp": {
        "pyright": {
           "disabled": true
        },
        "clangd": {
           "disabled": true
        }
    }
}
